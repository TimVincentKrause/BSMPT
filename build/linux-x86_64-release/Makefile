# Build rule for target.
MinimumTracer: cmake_check_build_system
	$(MAKE) $(MAKESILENT) -f CMakeFiles/Makefile2 MinimumTracer
.PHONY : MinimumTracer

# fast build rule for target.
MinimumTracer/fast:
	$(MAKE) $(MAKESILENT) -f src/minimum_tracer/CMakeFiles/MinimumTracer.dir/build.make src/minimum_tracer/CMakeFiles/MinimumTracer.dir/build
.PHONY : MinimumTracer/fast

